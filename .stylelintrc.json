{
  "customSyntax": "postcss-html",
  "rules": {
    "declaration-no-important": [true, { "severity": "error" }],
    "color-named": ["never", { "severity": "error" }],
    "color-no-invalid-hex": [true, { "severity": "error" }]
  },
  "overrides": [
    {
      "files": ["**/*.vue"],
      "customSyntax": "postcss-html"
    },
    {
      "files": ["**/*.css"],
      "customSyntax": "postcss",
      "rules": {
        "declaration-no-important": null
      }
    }
  ]
}
