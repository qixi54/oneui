{
  "name": "@oneflowui/ui",
  "version": "0.2.0",
  "description": "OneFlow UI Component Library - Vue3 components for task management views",
  "type": "module",
  "main": "./dist/oneflow-ui.umd.cjs",
  "module": "./dist/oneflow-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/oneflow-ui.js",
      "require": "./dist/oneflow-ui.umd.cjs"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --port 5174 --host",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src"
  },
  "peerDependencies": {
    "mermaid": ">=10.0.0",
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "mermaid": {
      "optional": true
    }
  },
  "dependencies": {
    "@vueup/vue-quill": "^1.2.0",
    "echarts": "^5.6.0",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^0.400.0",
    "marked": "^17.0.3",
    "quill": "^2.0.3",
    "vue-draggable-plus": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^24.1.3",
    "mermaid": "^11.12.3",
    "oxfmt": "^0.35.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.8",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
